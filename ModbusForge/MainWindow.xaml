<ui:FluentWindow x:Class="ModbusForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ModbusForge"
        xmlns:viewmodels="clr-namespace:ModbusForge.ViewModels"
        xmlns:views="clr-namespace:ModbusForge.Views"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="1073" Width="1556"
        WindowState="Maximized"
        Icon="pack://application:,,,/Resources/ModbusForgeLOGO.png"
        BorderThickness="1"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Window.InputBindings>
        <KeyBinding Key="R" Modifiers="Control" Command="{Binding ReadRegistersCommand}"/>
        <KeyBinding Key="T" Modifiers="Control" Command="{Binding TrendCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding ShowScriptEditorCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </Window.InputBindings>

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- XAML option arrays to avoid designer dependency on code -->
            <x:Array x:Key="ModeOptionsAll" Type="{x:Type sys:String}">
                <sys:String>Client</sys:String>
                <sys:String>Server</sys:String>
            </x:Array>
            <x:Array x:Key="TypeOptionsAll" Type="{x:Type sys:String}">
                <sys:String>uint</sys:String>
                <sys:String>int</sys:String>
                <sys:String>real</sys:String>
                <sys:String>string</sys:String>
            </x:Array>
            <x:Array x:Key="WaveformOptionsAll" Type="{x:Type sys:String}">
                <sys:String>Ramp</sys:String>
                <sys:String>Sine</sys:String>
                <sys:String>Triangle</sys:String>
                <sys:String>Square</sys:String>
            </x:Array>
            <x:Array x:Key="AreaOptionsAll" Type="{x:Type sys:String}">
                <sys:String>HoldingRegister</sys:String>
                <sys:String>Coil</sys:String>
                <sys:String>InputRegister</sys:String>
                <sys:String>DiscreteInput</sys:String>
            </x:Array>

            <!-- Tabs that look like classic tabs -->
            <Style TargetType="TabItem" BasedOn="{x:Null}"/>

            <Style TargetType="TabControl" BasedOn="{x:Null}"/>

            <!-- DataGrid: show gridlines and alternating rows for clarity -->
            <Style TargetType="DataGrid">
                <Setter Property="GridLinesVisibility" Value="All"/>
                <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource GrayBrush6}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource GrayBrush6}"/>
                <Setter Property="AlternationCount" Value="2"/>
                <Setter Property="AlternatingRowBackground" Value="#0D000000"/>
                <Setter Property="RowBackground" Value="Transparent"/>
                <Setter Property="EnableRowVirtualization" Value="True"/>
                <Setter Property="EnableColumnVirtualization" Value="True"/>
            </Style>

            <!-- Modern Button Style -->
            <Style TargetType="Button">
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Margin" Value="4,2"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <!-- GroupBox Style -->
            <Style TargetType="GroupBox">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <!-- StatusBar Style -->
            <Style TargetType="StatusBar">
                <Setter Property="Background" Value="#FF2D2D30"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="Medium"/>
            </Style>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- TitleBar -->
            <RowDefinition Height="Auto"/> <!-- Menu -->
            <RowDefinition Height="*"/>    <!-- Main Body -->
            <RowDefinition Height="Auto"/> <!-- StatusBar -->
        </Grid.RowDefinitions>

        <ui:TitleBar Title="{Binding Title}" Grid.Row="0">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Resources/ModbusForgeLOGO.png"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Menu Grid.Row="1">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Project..." Command="{Binding LoadProjectCommand}" InputGestureText="Ctrl+O" ToolTip="Open an existing project (Ctrl+O)"/>
                <MenuItem Header="_Save Project..." Command="{Binding SaveProjectCommand}" InputGestureText="Ctrl+S" ToolTip="Save the current project (Ctrl+S)"/>
                <Separator/>
                <MenuItem Header="_Import Unit IDs..." Command="{Binding ImportUnitIdsCommand}"/>
                <MenuItem Header="_Export Unit IDs..." Command="{Binding ExportUnitIdsCommand}"/>
                <Separator/>
                <MenuItem Header="Export Unit ID..." Command="{Binding ExportUnitIdCommand}"/>
                <MenuItem Header="Import Unit ID As..." Command="{Binding ImportUnitIdAsCommand}"/>
                <Separator/>
                <!-- Legacy commands - hidden but kept for compatibility -->
                <MenuItem Header="_Load All Configuration..." Command="{Binding LoadAllConfigCommand}" Visibility="Collapsed"/>
                <MenuItem Header="_Save All Configuration..." Command="{Binding SaveAllConfigCommand}" Visibility="Collapsed"/>
                <MenuItem Header="_Load Custom..." Command="{Binding LoadCustomCommand}" Visibility="Collapsed"/>
                <MenuItem Header="_Save Custom..." Command="{Binding SaveCustomCommand}" Visibility="Collapsed"/>
                <Separator/>
                <MenuItem Header="_Exit" Click="MenuItem_Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Trend">
                <MenuItem Header="Export _CSV..." Command="{Binding ElementName=TrendViewControl, Path=DataContext.ExportCsvCommand}" InputGestureText="Ctrl+Shift+E"/>
                <MenuItem Header="Export _PNG..." Click="Trend_ExportPng_Click"/>
                <MenuItem Header="_Import CSV..." Command="{Binding ElementName=TrendViewControl, Path=DataContext.ImportCsvCommand}" InputGestureText="Ctrl+Shift+I"/>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="_Preferences..." Click="MenuItem_Preferences_Click"/>
                <MenuItem Header="_Connection Manager..." Click="MenuItem_ConnectionManager_Click"/>
                <MenuItem Header="_Script Editor..." Click="MenuItem_ScriptEditor_Click" InputGestureText="Ctrl+E" ToolTip="Open the script editor (Ctrl+E)"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Simulation _Palette" Click="MenuItem_ShowSimPalette_Click"/>
                <MenuItem Header="Simulation _Controls" Click="MenuItem_ShowSimControls_Click"/>
                <MenuItem Header="Simulation _Programs" Click="MenuItem_ShowSimPrograms_Click"/>
                <Separator/>
                <MenuItem Header="_Registers" IsCheckable="True" IsChecked="{Binding IsRegistersTabVisible}" ToolTip="Show/hide Registers tab"/>
                <MenuItem Header="_Input Registers" IsCheckable="True" IsChecked="{Binding IsInputRegistersTabVisible}" ToolTip="Show/hide Input Registers tab"/>
                <MenuItem Header="_Coils" IsCheckable="True" IsChecked="{Binding IsCoilsTabVisible}" ToolTip="Show/hide Coils tab"/>
                <MenuItem Header="_Discrete Inputs" IsCheckable="True" IsChecked="{Binding IsDiscreteInputsTabVisible}" ToolTip="Show/hide Discrete Inputs tab"/>
                <MenuItem Header="_Custom Watch" IsCheckable="True" IsChecked="{Binding IsCustomWatchTabVisible}" ToolTip="Show/hide Custom Watch tab"/>
                <MenuItem Header="_Simulation" IsCheckable="True" IsChecked="{Binding IsSimulationTabVisible}" ToolTip="Show/hide Simulation tab"/>
                <MenuItem Header="_Decode" IsCheckable="True" IsChecked="{Binding IsDecodeTabVisible}" ToolTip="Show/hide Decode tab"/>
                <MenuItem Header="_Trend" IsCheckable="True" IsChecked="{Binding IsTrendTabVisible}" ToolTip="Show/hide Trend tab"/>
                <MenuItem Header="_Console" IsCheckable="True" IsChecked="{Binding IsConsoleTabVisible}" ToolTip="Show/hide Console tab"/>
                <MenuItem Header="_Debug" IsCheckable="True" IsChecked="{Binding IsDebugTabVisible}" ToolTip="Show/hide Debug tab"/>
                <Separator/>
                <MenuItem Header="_Show All" Click="WindowMenu_ShowAll_Click"/>
                <MenuItem Header="_Reset to Default" Click="WindowMenu_Reset_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Help..." Click="MenuItem_Help_Click" InputGestureText="F1" ToolTip="Open the help window (F1)"/>
                <MenuItem Header="_Keyboard Shortcuts..." Click="MenuItem_KeyboardShortcuts_Click" ToolTip="View all keyboard shortcuts"/>
                <MenuItem Header="_Troubleshooting..." Click="MenuItem_Troubleshooting_Click" ToolTip="View troubleshooting guide and export diagnostics"/>
                <Separator/>
                <MenuItem Header="_About" Click="MenuItem_About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main Body: Sidebar on Left, Connection Bar & TabControl on Right -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Navigation sidebar -->
                <ColumnDefinition Width="*"/>    <!-- Main Right Content -->
            </Grid.ColumnDefinitions>

            <ui:NavigationView x:Name="RootNavigation" Grid.Column="0" 
                               PaneDisplayMode="Left" 
                               IsBackButtonVisible="Collapsed" 
                               IsPaneToggleVisible="True"
                               OpenPaneLength="175">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Content="Registers" Icon="{ui:SymbolIcon Symbol=Database24}" Tag="0" PreviewMouseLeftButtonDown="NavItem_MouseDown"/>
                    <ui:NavigationViewItem Content="Input Registers" Icon="{ui:SymbolIcon Symbol=DatabaseSearch24}" Tag="1" PreviewMouseLeftButtonDown="NavItem_MouseDown"/>
                    <ui:NavigationViewItem Content="Coils" Icon="{ui:SymbolIcon Symbol=ToggleLeft24}" Tag="2" PreviewMouseLeftButtonDown="NavItem_MouseDown"/>
                    <ui:NavigationViewItem Content="Discrete Inputs" Icon="{ui:SymbolIcon Symbol=ToggleRight24}" Tag="3" PreviewMouseLeftButtonDown="NavItem_MouseDown"/>
                    <ui:NavigationViewItem Content="Custom Watch" Icon="{ui:SymbolIcon Symbol=Star24}" Tag="4" PreviewMouseLeftButtonDown="NavItem_MouseDown"/>
                    <ui:NavigationViewItem Content="Simulation" Icon="{ui:SymbolIcon Symbol=VirtualNetwork24}" Tag="5" PreviewMouseLeftButtonDown="NavItem_MouseDown" AutomationProperties.AutomationId="SimulationNavItem"/>
                    <ui:NavigationViewItem Content="Decode" Icon="{ui:SymbolIcon Symbol=Code24}" Tag="6" PreviewMouseLeftButtonDown="NavItem_MouseDown"/>
                    <ui:NavigationViewItem Content="Trend" Icon="{ui:SymbolIcon Symbol=DataTrending24}" Tag="7" PreviewMouseLeftButtonDown="NavItem_MouseDown"/>
                    <ui:NavigationViewItem Content="Console" Icon="{ui:SymbolIcon Symbol=WindowConsole20}" Tag="8" PreviewMouseLeftButtonDown="NavItem_MouseDown"/>
                    <ui:NavigationViewItem Content="Debug" Icon="{ui:SymbolIcon Symbol=Bug24}" Tag="9" PreviewMouseLeftButtonDown="NavItem_MouseDown"/>
                    <ui:NavigationViewItemSeparator/>
                    <ui:NavigationViewItem Content="Script Editor" Icon="{ui:SymbolIcon Symbol=Edit24}" Tag="ScriptEditor" PreviewMouseLeftButtonDown="NavItem_MouseDown"/>
                </ui:NavigationView.MenuItems>
            </ui:NavigationView>

            <!-- Right Content Area containing the Connection Bar and DockingManager -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Connection Bar -->
                    <RowDefinition Height="*"/>    <!-- Content Area -->
                </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Margin="16,8,16,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="{Binding ConnectionHeader}" Style="{StaticResource ModernTitleStyle}"/>
                        <Ellipse Style="{StaticResource StatusIndicatorStyle}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource ModernBodyStyle}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding AddressLabel}" Grid.Column="0" Style="{StaticResource ModernBodyStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Text="{Binding ServerAddress, UpdateSourceTrigger=PropertyChanged}" 
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}" 
                                 Margin="0,0,16,0"/>

                        <TextBlock Text="Port:" Grid.Column="2" Style="{StaticResource ModernBodyStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="3" Text="{Binding Port}" 
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}" 
                                 Margin="0,0,16,0"/>

                        <TextBlock Text="Unit ID:" Grid.Column="4" Style="{StaticResource ModernBodyStyle}" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="{Binding ShowClientFields, Converter={StaticResource BoolToVis}}"/>
                        <TextBox Grid.Column="5" Text="{Binding UnitId}" 
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}" 
                                 Margin="0,0,16,0" Visibility="{Binding ShowClientFields, Converter={StaticResource BoolToVis}}"/>

                        <TextBlock Text="Unit ID(s):" Grid.Column="4" Style="{StaticResource ModernBodyStyle}" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVis}}"/>
                        <TextBox Grid.Column="5" Text="{Binding ServerUnitId}" 
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}" 
                                 Margin="0,0,16,0" Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVis}}"
                                 ToolTip="Comma-separated list (e.g. 1, 2, 5-10)"/>

                        <TextBlock Text="Active ID:" Grid.Column="6" Style="{StaticResource ModernBodyStyle}" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVis}}"/>
                        <ComboBox Grid.Column="7" ItemsSource="{Binding AvailableUnitIds}" SelectedItem="{Binding SelectedUnitId}" 
                                  IsEnabled="{Binding IsConnected}" 
                                  Margin="0,0,16,0" Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVis}}"
                                  ToolTip="Select Unit ID for Custom entries and Simulation"/>

                        <TextBlock Text="Mode:" Grid.Column="8" Style="{StaticResource ModernBodyStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="9" SelectedItem="{Binding Mode}" ItemsSource="{StaticResource ModeOptionsAll}"
                                  IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"
                                  Margin="0,0,16,0"
                                  AutomationProperties.AutomationId="ModeComboBox"/>

                        <Button Grid.Column="10" Content="{Binding ConnectButtonText}" Command="{Binding ConnectCommand}"
                                IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"
                                Style="{StaticResource MetallicButtonStyle}" Margin="0,0,8,0"
                                AutomationProperties.AutomationId="ConnectButton"/>

                        <StackPanel Grid.Column="11" Orientation="Horizontal">
                            <Button Content="Disconnect" Command="{Binding DisconnectCommand}" 
                                    IsEnabled="{Binding IsConnected}"
                                    Style="{StaticResource MetallicButtonStyle}" Margin="0,0,8,0"
                                    AutomationProperties.AutomationId="DisconnectButton"/>
                            <Button Content="Diagnostics" Command="{Binding RunDiagnosticsCommand}" 
                                    ToolTip="Test TCP and Modbus connectivity"
                                    Style="{StaticResource MetallicButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <avalonDock:DockingManager x:Name="MainDockingManager" Grid.Row="1" Margin="5">
                <avalonDock:LayoutRoot>
                    <avalonDock:LayoutPanel Orientation="Horizontal">
                        <avalonDock:LayoutDocumentPane x:Name="MainDocumentPane">
                            <avalonDock:LayoutDocument CanClose="False" x:Name="DocRegisters" Title="Registers" ContentId="Registers">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Start:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Width="80" Text="{Binding RegisterStart}" Margin="0,0,10,0"/>
                        <TextBlock Text="Count:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Width="80" Text="{Binding RegisterCount}" Margin="0,0,10,0"/>
                        <Button Content="Read" Command="{Binding ReadRegistersCommand}" Width="80" Margin="0,0,10,0"/>
                        <TextBlock Text="Global Type:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <ComboBox Width="120" SelectedItem="{Binding RegistersGlobalType}" ItemsSource="{StaticResource TypeOptionsAll}"/>
                        <Separator Width="10" Opacity="0"/>
                        <ui:ToggleSwitch IsChecked="{Binding HoldingMonitorEnabled, Mode=TwoWay}" Content="Continuous Read" VerticalAlignment="Center"/>
                        <TextBlock Text=" Period (ms):" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <TextBox Width="80" Text="{Binding HoldingMonitorPeriodMs}"/>
                        <Separator Width="20" Opacity="0"/>
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ui:TextBox Width="150" Text="{Binding HoldingSearchText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Address, value, type..."/>
                    </StackPanel>

                    <DataGrid x:Name="HoldingRegistersGrid" Grid.Row="1" ItemsSource="{Binding HoldingRegistersView}" AutoGenerateColumns="False" IsReadOnly="False" CellEditEnding="HoldingRegistersGrid_CellEditEnding" MouseDoubleClick="HoldingRegistersGrid_MouseDoubleClick"
                              VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.ScrollUnit="Pixel">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Quick Write..." Click="HoldingRegisters_Write_Click"/>
                                <MenuItem Header="Add to Custom Watch" Click="HoldingRegisters_AddToCustom_Click"/>
                                <MenuItem Header="Add to Trend View" Click="HoldingRegisters_AddToTrend_Click"/>
                                <Separator/>
                                <MenuItem Header="Copy Address" Click="HoldingRegisters_CopyAddress_Click"/>
                                <MenuItem Header="Copy Value" Click="HoldingRegisters_CopyValue_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding ValueText}" Width="*"/>
                            <DataGridComboBoxColumn Header="Type" SelectedItemBinding="{Binding Type}" ItemsSource="{StaticResource TypeOptionsAll}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument CanClose="False" x:Name="DocInputRegisters" Title="Input Registers" ContentId="InputRegisters">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Start:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Width="80" Text="{Binding InputRegisterStart}" Margin="0,0,10,0"/>
                        <TextBlock Text="Count:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Width="80" Text="{Binding InputRegisterCount}" Margin="0,0,10,0"/>
                        <Button Content="Read" Command="{Binding ReadInputRegistersCommand}" Width="80" Margin="0,0,10,0"/>
                        <TextBlock Text="Global Type:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <ComboBox Width="120" SelectedItem="{Binding InputRegistersGlobalType}" ItemsSource="{StaticResource TypeOptionsAll}"/>
                        <Separator Width="10" Opacity="0"/>
                        <ui:ToggleSwitch IsChecked="{Binding InputRegistersMonitorEnabled, Mode=TwoWay}" Content="Continuous Read" VerticalAlignment="Center"/>
                        <TextBlock Text=" Period (ms):" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <TextBox Width="80" Text="{Binding InputRegistersMonitorPeriodMs}"/>
                        <Separator Width="20" Opacity="0"/>
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ui:TextBox Width="150" Text="{Binding InputSearchText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Address, value, type..."/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding InputRegistersView}" AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="InputRegistersGrid_MouseDoubleClick"
                              VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.ScrollUnit="Pixel">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add to Custom Watch" Click="InputRegisters_AddToCustom_Click"/>
                                <MenuItem Header="Add to Trend View" Click="InputRegisters_AddToTrend_Click"/>
                                <Separator/>
                                <MenuItem Header="Copy Address" Click="InputRegisters_CopyAddress_Click"/>
                                <MenuItem Header="Copy Value" Click="InputRegisters_CopyValue_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument CanClose="False" x:Name="DocCoils" Title="Coils" ContentId="Coils">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Start:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Width="80" Text="{Binding CoilStart}" Margin="0,0,10,0"/>
                        <TextBlock Text="Count:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Width="80" Text="{Binding CoilCount}" Margin="0,0,10,0"/>
                        <Button Content="Read" Command="{Binding ReadCoilsCommand}" Width="80"/>
                        <Separator Width="10" Opacity="0"/>
                        <ui:ToggleSwitch IsChecked="{Binding CoilsMonitorEnabled, Mode=TwoWay}" Content="Continuous Read" VerticalAlignment="Center"/>
                        <TextBlock Text=" Period (ms):" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <TextBox Width="80" Text="{Binding CoilsMonitorPeriodMs}"/>
                        <Separator Width="20" Opacity="0"/>
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ui:TextBox Width="150" Text="{Binding CoilsSearchText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Address, state..."/>
                    </StackPanel>

                    <DataGrid x:Name="CoilsGrid" Grid.Row="1" ItemsSource="{Binding CoilsView}" AutoGenerateColumns="False" IsReadOnly="False" CellEditEnding="CoilsGrid_CellEditEnding" CurrentCellChanged="CoilsGrid_CurrentCellChanged" MouseDoubleClick="CoilsGrid_MouseDoubleClick"
                              VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.ScrollUnit="Pixel">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Quick Write..." Click="Coils_Write_Click"/>
                                <MenuItem Header="Add to Custom Watch" Click="Coils_AddToCustom_Click"/>
                                <Separator/>
                                <MenuItem Header="Copy Address" Click="Coils_CopyAddress_Click"/>
                                <MenuItem Header="Copy State" Click="Coils_CopyState_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                            <DataGridCheckBoxColumn Header="State" Binding="{Binding State}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument CanClose="False" x:Name="DocDiscreteInputs" Title="Discrete Inputs" ContentId="DiscreteInputs">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Start:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Width="80" Text="{Binding DiscreteInputStart}" Margin="0,0,10,0"/>
                        <TextBlock Text="Count:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Width="80" Text="{Binding DiscreteInputCount}" Margin="0,0,10,0"/>
                        <Button Content="Read" Command="{Binding ReadDiscreteInputsCommand}" Width="80"/>
                        <Separator Width="10" Opacity="0"/>
                        <ui:ToggleSwitch IsChecked="{Binding DiscreteInputsMonitorEnabled, Mode=TwoWay}" Content="Continuous Read" VerticalAlignment="Center"/>
                        <TextBlock Text=" Period (ms):" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <TextBox Width="80" Text="{Binding DiscreteInputsMonitorPeriodMs}"/>
                        <Separator Width="20" Opacity="0"/>
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ui:TextBox Width="150" Text="{Binding DiscreteSearchText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Address, state..."/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding DiscreteInputsView}" AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="DiscreteInputsGrid_MouseDoubleClick"
                              VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.ScrollUnit="Pixel">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add to Custom Watch" Click="DiscreteInputs_AddToCustom_Click"/>
                                <Separator/>
                                <MenuItem Header="Copy Address" Click="DiscreteInputs_CopyAddress_Click"/>
                                <MenuItem Header="Copy State" Click="DiscreteInputs_CopyState_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                            <DataGridCheckBoxColumn Header="State" Binding="{Binding State}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument CanClose="False" x:Name="DocCustomWatch" Title="Custom Watch" ContentId="CustomWatch">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <Button Content="Add" Command="{Binding AddCustomEntryCommand}" Width="80"/>
                        <Separator Width="10" Opacity="0"/>
                        <Button Content="Read All" Command="{Binding ReadAllCustomNowCommand}" Width="80"/>
                        <Separator Width="10" Opacity="0"/>
                        <Button Content="Save" Command="{Binding SaveCustomCommand}" Width="80"/>
                        <Button Content="Load" Command="{Binding LoadCustomCommand}" Width="80" Margin="5,0,0,0"/>
                        <Separator Width="20" Opacity="0"/>
                        <ui:ToggleSwitch IsChecked="{Binding GlobalMonitorEnabled, Mode=TwoWay}" Content="Global Monitor" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock VerticalAlignment="Center" Foreground="Gray">
                            <Run Text="Note:" FontWeight="SemiBold"/>
                            <Run Text=" Reads Trend-enabled rows."/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Custom entries grid -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding CustomEntries}" AutoGenerateColumns="False" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridComboBoxColumn Header="Area" SelectedItemBinding="{Binding Area}" ItemsSource="{StaticResource AreaOptionsAll}" Width="*"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                            <DataGridComboBoxColumn Header="Type" SelectedItemBinding="{Binding Type}" ItemsSource="{StaticResource TypeOptionsAll}" Width="*"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*"/>
                            <DataGridCheckBoxColumn Header="Cont. Write" Binding="{Binding Continuous}" Width="Auto"/>
                            <DataGridTextColumn Header="Write Period (ms)" Binding="{Binding PeriodMs}" Width="*"/>
                            <DataGridCheckBoxColumn Header="Trend" Binding="{Binding Trend}" Width="Auto"/>
                            <DataGridTemplateColumn Header="Actions" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Write" Padding="8,2" Margin="0,0,5,0"
                                                    Command="{Binding DataContext.WriteCustomNowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding ., FallbackValue={x:Null}, TargetNullValue={x:Null}}"/>
                                            <Button Content="Read" Padding="8,2"
                                                    Command="{Binding DataContext.ReadCustomNowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding ., FallbackValue={x:Null}, TargetNullValue={x:Null}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument CanClose="False" x:Name="DocSimulation" Title="Simulation" ContentId="Simulation">
                <views:VisualNodeEditor x:Name="VisualEditor" DataContext="{Binding VisualNodeEditorViewModel}"/>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument CanClose="False" x:Name="DocDecode" Title="Decode" ContentId="Decode">
                <Grid Margin="5">
                    <views:DecodeView x:Name="DecodeViewControl" />
                </Grid>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument CanClose="False" x:Name="DocTrend" Title="Trend" ContentId="Trend">
                <Grid Margin="5">
                    <views:TrendView x:Name="TrendViewControl" />
                </Grid>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument CanClose="False" x:Name="DocConsole" Title="Console" ContentId="Console">
                <Grid Margin="5">
                    <ListView ItemsSource="{Binding ConsoleMessages}" />
                </Grid>
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument CanClose="False" x:Name="DocDebug" Title="Debug" ContentId="Debug">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Live Register Values" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding DebugMessages}" />
                </Grid>
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>
                    </avalonDock:LayoutPanel>
                </avalonDock:LayoutRoot>
            </avalonDock:DockingManager>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="0,0,20,0">
                        <Run Text="Version:" FontWeight="SemiBold"/>
                        <Run Text="{Binding Version}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Status:" FontWeight="SemiBold"/>
                        <Run Text="{Binding IsConnected, Converter={StaticResource BooleanToConnectedConverter}}"/>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</ui:FluentWindow>
