<ui:FluentWindow x:Class="ModbusForge.ScriptEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:models="clr-namespace:ModbusForge.Models"
        xmlns:behaviors="clr-namespace:ModbusForge.Behaviors"
        Title="Script Editor" 
        Height="720" 
        Width="1000"
        MinWidth="900"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/ModbusForgeLOGO.png"
        ResizeMode="CanResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource FluentBackground}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="180"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="{StaticResource FluentPrimary}" Padding="16,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Script Editor" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource FluentCardBackground}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Script Settings -->
            <Border Grid.Row="1" 
                    Background="{StaticResource FluentCardBackground}" 
                    BorderBrush="{StaticResource FluentBorder}" 
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource FluentText}"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding Script.Name, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,4"
                             Background="{StaticResource FluentCardBackground}"
                             BorderBrush="{StaticResource FluentBorder}"
                             BorderThickness="1"/>

                    <TextBlock Grid.Column="2" Text="Repeat:" VerticalAlignment="Center" Margin="16,0,8,0" Foreground="{StaticResource FluentText}"/>
                    <TextBox Grid.Column="3" 
                             Text="{Binding Script.RepeatCount, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,4"
                             Background="{StaticResource FluentCardBackground}"
                             BorderBrush="{StaticResource FluentBorder}"
                             BorderThickness="1"
                             behaviors:NumericTextBoxBehavior.IsNumeric="True"
                             behaviors:NumericTextBoxBehavior.Format="UInteger"/>

                    <TextBlock Grid.Column="4" Text="Delay (ms):" VerticalAlignment="Center" Margin="16,0,8,0" Foreground="{StaticResource FluentText}"/>
                    <TextBox Grid.Column="5" 
                             Text="{Binding Script.DelayBetweenCommandsMs, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,4"
                             Background="{StaticResource FluentCardBackground}"
                             BorderBrush="{StaticResource FluentBorder}"
                             BorderThickness="1"
                             behaviors:NumericTextBoxBehavior.IsNumeric="True"
                             behaviors:NumericTextBoxBehavior.Format="UInteger"/>

                    <ui:ToggleSwitch Grid.Column="6" 
                                     Content="Stop on Error" 
                                     VerticalAlignment="Center" 
                                     Margin="16,0,0,0"
                                     IsChecked="{Binding Script.StopOnError}"/>
                </Grid>
            </Border>

            <!-- Commands List -->
            <Border Grid.Row="2" Background="{StaticResource FluentCardBackground}" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" 
                            BorderBrush="{StaticResource FluentBorder}" 
                            BorderThickness="1" 
                            CornerRadius="4"
                            MinWidth="300">
                        <DataGrid x:Name="CommandsGrid"
                                  ItemsSource="{Binding Script.Commands}"
                                  SelectedItem="{Binding SelectedCommand}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  GridLinesVisibility="All"
                                  VerticalGridLinesBrush="{StaticResource FluentBorder}"
                                  HorizontalGridLinesBrush="{StaticResource FluentBorder}"
                                  RowBackground="{StaticResource FluentCardBackground}"
                                  AlternatingRowBackground="{StaticResource FluentSurface}"
                                  BorderThickness="0"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="55"/>
                                <DataGridComboBoxColumn Header="Type" Width="160"
                                                        SelectedItemBinding="{Binding CommandType}"
                                                        ItemsSource="{Binding Source={x:Static models:ScriptCommandType.ReadHoldingRegisters}}"/>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="80">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="behaviors:NumericTextBoxBehavior.IsNumeric" Value="True"/>
                                            <Setter Property="behaviors:NumericTextBoxBehavior.Format" Value="UInteger"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="60">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="behaviors:NumericTextBoxBehavior.IsNumeric" Value="True"/>
                                            <Setter Property="behaviors:NumericTextBoxBehavior.Format" Value="UInteger"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="80">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="behaviors:NumericTextBoxBehavior.IsNumeric" Value="True"/>
                                            <Setter Property="behaviors:NumericTextBoxBehavior.Format" Value="UInteger"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Description" Binding="{Binding DisplayText}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Last Result" Binding="{Binding LastResult}" Width="150" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <Button Content="Add" Width="90" Margin="0,0,0,6" Click="AddCommand_Click" Style="{StaticResource FluentSecondaryButton}"/>
                        <Button Content="Remove" Width="90" Margin="0,0,0,6" Click="RemoveCommand_Click" Style="{StaticResource FluentSecondaryButton}"/>
                        <Button Content="Move Up" Width="90" Margin="0,0,0,6" Click="MoveUp_Click" Style="{StaticResource FluentSecondaryButton}"/>
                        <Button Content="Move Down" Width="90" Margin="0,0,0,6" Click="MoveDown_Click" Style="{StaticResource FluentSecondaryButton}"/>
                        <Separator Margin="0,10"/>
                        <Button Content="Clone" Width="90" Margin="0,0,0,6" Click="CloneCommand_Click" Style="{StaticResource FluentSecondaryButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Run Controls -->
            <Border Grid.Row="3" 
                    Background="{StaticResource FluentSurface}" 
                    BorderBrush="{StaticResource FluentBorder}" 
                    BorderThickness="0,1,0,1"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="RunButton" 
                            Content="Run Script" 
                            Width="120" 
                            Margin="0,0,10,0" 
                            Click="RunScript_Click"
                            Background="{StaticResource FluentPrimary}"
                            Foreground="{StaticResource FluentCardBackground}"
                            Padding="12,8"/>
                    <Button x:Name="StopButton" 
                            Content="Stop" 
                            Width="80" 
                            Margin="0,0,10,0" 
                            Click="StopScript_Click"
                            Background="{StaticResource FluentStatusError}"
                            Foreground="{StaticResource FluentCardBackground}"
                            IsEnabled="False"
                            Padding="12,8"/>
                    <TextBlock x:Name="StatusText" 
                               VerticalAlignment="Center" 
                               Margin="10,0,0,0" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FluentText}"/>
                </StackPanel>
            </Border>

            <!-- Output Log -->
            <Border Grid.Row="4" Background="{StaticResource FluentCardBackground}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Output Log" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource FluentText}"
                               Margin="0,0,0,8"/>
                    <Border Grid.Row="1" 
                            BorderBrush="{StaticResource FluentBorder}" 
                            BorderThickness="1" 
                            CornerRadius="4"
                            Background="{StaticResource FluentSurface}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="OutputLog" 
                                     Grid.Column="0" 
                                     FontFamily="Consolas" 
                                     FontSize="11"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Margin="8"/>
                            <Button Grid.Column="1" 
                                    Content="Clear" 
                                    Width="70" 
                                    VerticalAlignment="Top" 
                                    Margin="0,8,8,0" 
                                    Click="ClearLog_Click"
                                    Style="{StaticResource FluentSecondaryButton}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Bottom Buttons -->
            <Border Grid.Row="5" 
                    Background="{StaticResource FluentSurface}" 
                    BorderBrush="{StaticResource FluentBorder}" 
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save Script..." Width="110" Margin="0,0,10,0" Click="SaveScript_Click" Style="{StaticResource FluentSecondaryButton}"/>
                    <Button Content="Load Script..." Width="110" Margin="0,0,10,0" Click="LoadScript_Click" Style="{StaticResource FluentSecondaryButton}"/>
                    <Button Content="Close" Width="90" Click="Close_Click" Style="{StaticResource FluentPrimaryButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</ui:FluentWindow>
