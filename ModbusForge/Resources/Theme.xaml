<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Modern Light Metallic Color Scheme -->
    <Color x:Key="LightMetallicWhite">#FFF8F8F8</Color>
    <Color x:Key="LightMetallicSilver">#FFE8E8E8</Color>
    <Color x:Key="LightMetallicChrome">#FFD9D9D9</Color>
    <Color x:Key="LightMetallicSteel">#FFC0C0C0</Color>
    <Color x:Key="LightMetallicDarkSilver">#FF808080</Color>
    <Color x:Key="LightMetallicAccent">#FF0078D4</Color>
    <Color x:Key="LightMetallicAccentHover">#FF106EBE</Color>
    <Color x:Key="LightMetallicText">#FF323130</Color>
    <Color x:Key="LightMetallicTextSecondary">#FF605E5C</Color>
    <Color x:Key="LightMetallicBorder">#FFE1DFDD</Color>
    <Color x:Key="LightMetallicCard">#FFFFFFFF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="LightMetallicWhiteBrush" Color="{StaticResource LightMetallicWhite}"/>
    <SolidColorBrush x:Key="LightMetallicSilverBrush" Color="{StaticResource LightMetallicSilver}"/>
    <SolidColorBrush x:Key="LightMetallicChromeBrush" Color="{StaticResource LightMetallicChrome}"/>
    <SolidColorBrush x:Key="LightMetallicSteelBrush" Color="{StaticResource LightMetallicSteel}"/>
    <SolidColorBrush x:Key="LightMetallicDarkSilverBrush" Color="{StaticResource LightMetallicDarkSilver}"/>
    <SolidColorBrush x:Key="LightMetallicAccentBrush" Color="{StaticResource LightMetallicAccent}"/>
    <SolidColorBrush x:Key="LightMetallicAccentHoverBrush" Color="{StaticResource LightMetallicAccentHover}"/>
    <SolidColorBrush x:Key="LightMetallicTextBrush" Color="{StaticResource LightMetallicText}"/>
    <SolidColorBrush x:Key="LightMetallicTextSecondaryBrush" Color="{StaticResource LightMetallicTextSecondary}"/>
    <SolidColorBrush x:Key="LightMetallicBorderBrush" Color="{StaticResource LightMetallicBorder}"/>
    <SolidColorBrush x:Key="LightMetallicCardBrush" Color="{StaticResource LightMetallicCard}"/>

    <!-- Semantic status brushes (use instead of raw reds/greens) -->
    <SolidColorBrush x:Key="LightMetallicStatusSuccessBrush" Color="#107C10"/>
    <SolidColorBrush x:Key="LightMetallicStatusErrorBrush" Color="#D13438"/>

    <!-- Metallic Button Style with Hover Effect -->
    <Style x:Key="MetallicButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource LightMetallicChromeBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource LightMetallicTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LightMetallicSteelBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <Border.Effect>
                            <DropShadowEffect x:Name="shadow"
                                            Color="#FF999999"
                                            Direction="270"
                                            ShadowDepth="1"
                                            BlurRadius="3"
                                            Opacity="0.3"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                      To="{StaticResource LightMetallicSilver}"
                                                      Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                      Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                      To="{StaticResource LightMetallicAccent}"
                                                      Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="shadow"
                                                       Storyboard.TargetProperty="BlurRadius"
                                                       To="6"
                                                       Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                      To="{StaticResource LightMetallicChrome}"
                                                      Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                      Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                      To="{StaticResource LightMetallicSteel}"
                                                      Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="shadow"
                                                       Storyboard.TargetProperty="BlurRadius"
                                                       To="3"
                                                       Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource LightMetallicSteelBrush}"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF666666" Direction="270" ShadowDepth="0.5" BlurRadius="2" Opacity="0.4"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource LightMetallicWhiteBrush}"/>
                            <Setter TargetName="border" Property="TextElement.Foreground" Value="{StaticResource LightMetallicDarkSilverBrush}"/>
                            <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent Button Style (for primary actions) -->
    <Style x:Key="MetallicAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource MetallicButtonStyle}">
        <Setter Property="Background" Value="{StaticResource LightMetallicAccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <Border.Effect>
                            <DropShadowEffect x:Name="shadow"
                                            Color="{StaticResource LightMetallicAccent}"
                                            Direction="270"
                                            ShadowDepth="1"
                                            BlurRadius="4"
                                            Opacity="0.4"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                      To="{StaticResource LightMetallicAccentHover}"
                                                      Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="shadow"
                                                       Storyboard.TargetProperty="BlurRadius"
                                                       To="8"
                                                       Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                      Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                      To="{StaticResource LightMetallicAccent}"
                                                      Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="shadow"
                                                       Storyboard.TargetProperty="BlurRadius"
                                                       To="4"
                                                       Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource LightMetallicChromeBrush}"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource LightMetallicAccent}" Direction="270" ShadowDepth="0.5" BlurRadius="3" Opacity="0.5"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource LightMetallicWhiteBrush}"/>
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Apply to all buttons by default -->
    <Style TargetType="Button" BasedOn="{StaticResource MetallicButtonStyle}"/>

    <!-- Modern TextBox Style with Focus Animation -->
    <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource LightMetallicTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LightMetallicBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost" 
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource LightMetallicSteelBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                      Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                      To="{StaticResource LightMetallicAccent}"
                                                      Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border"
                                                      Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                      To="{StaticResource LightMetallicBorder}"
                                                      Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource LightMetallicSilverBrush}"/>
                            <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern GroupBox Style -->
    <Style x:Key="ModernGroupBoxStyle" TargetType="GroupBox">
        <Setter Property="BorderBrush" Value="{StaticResource LightMetallicBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource LightMetallicTextBrush}"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="Header" 
                                Grid.Row="0"
                                Padding="8,4"
                                Background="{StaticResource LightMetallicSilverBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0">
                            <ContentPresenter ContentSource="Header" 
                                            RecognizesAccessKey="True"
                                            TextElement.FontWeight="SemiBold"
                                            TextElement.Foreground="{StaticResource LightMetallicTextBrush}"/>
                        </Border>
                        <Border Grid.Row="1"
                                Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,0,1,1"
                                CornerRadius="0,0,4,4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern TabControl Style -->
    <Style x:Key="ModernTabItemStyle" TargetType="TabItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource LightMetallicTextBrush}"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource LightMetallicBorderBrush}"
                            BorderThickness="1,1,1,0"
                            CornerRadius="4,4,0,0"
                            Padding="{TemplateBinding Padding}"
                            Margin="0,0,2,0">
                        <ContentPresenter x:Name="contentPresenter"
                                        ContentSource="Header"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="White"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource LightMetallicAccentBrush}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="1,2,1,0"/>
                            <Setter TargetName="contentPresenter" Property="TextElement.FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Background" Value="{StaticResource LightMetallicSilverBrush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Status indicator styles -->
    <Style x:Key="StatusConnectedStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="Fill" Value="{StaticResource LightMetallicStatusSuccessBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#107C10" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatusDisconnectedStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="12"/>
        <Setter Property="Fill" Value="{StaticResource LightMetallicSteelBrush}"/>
    </Style>

    <!-- Card-like panel style -->
    <Style x:Key="CardPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource LightMetallicBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="15"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.1" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Card Style -->
    <Style x:Key="ModernCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource LightMetallicCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LightMetallicBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" Opacity="0.1" ShadowDepth="2" BlurRadius="8"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Typography Styles -->
    <Style x:Key="ModernTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource LightMetallicTextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="ModernSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource LightMetallicTextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="ModernBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource LightMetallicTextBrush}"/>
    </Style>

    <Style x:Key="ModernCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource LightMetallicTextSecondaryBrush}"/>
    </Style>

    <!-- Modern Status Indicator -->
    <Style x:Key="StatusIndicatorStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Fill" Value="{StaticResource LightMetallicSteelBrush}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                <Setter Property="Fill" Value="{StaticResource LightMetallicStatusSuccessBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                <Setter Property="Fill" Value="{StaticResource LightMetallicStatusErrorBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Apply styles globally -->
    <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}"/>
    <Style TargetType="GroupBox" BasedOn="{StaticResource ModernGroupBoxStyle}"/>
    <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItemStyle}"/>


    <!-- Modern Fluent Color Palette -->
    <SolidColorBrush x:Key="FluentBackground" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="FluentSurface" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="FluentCardBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FluentPrimary" Color="#0078D4"/>
    <SolidColorBrush x:Key="FluentPrimaryHover" Color="#106EBE"/>
    <SolidColorBrush x:Key="FluentAccent" Color="#0078D4"/>
    <SolidColorBrush x:Key="FluentText" Color="#323130"/>
    <SolidColorBrush x:Key="FluentTextSecondary" Color="#605E5C"/>
    <SolidColorBrush x:Key="FluentBorder" Color="#E1DFDD"/>
    <SolidColorBrush x:Key="FluentDivider" Color="#EDEBE9"/>

    <!-- Semantic status brushes (use these instead of hard-coded reds/greens) -->
    <SolidColorBrush x:Key="FluentStatusInfo" Color="#0078D4"/>
    <SolidColorBrush x:Key="FluentStatusError" Color="#D13438"/>
    <SolidColorBrush x:Key="FluentStatusWarning" Color="#FF8C00"/>
    <SolidColorBrush x:Key="FluentStatusSuccess" Color="#107C10"/>

    <!-- Modern Fluent Typography -->
    <Style x:Key="FluentTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentText}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="FluentSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource FluentText}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="FluentBody" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource FluentText}"/>
    </Style>

    <Style x:Key="FluentCaption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
    </Style>

    <!-- Modern Card Style -->
    <Style x:Key="FluentCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentCardBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" Opacity="0.1" ShadowDepth="2" BlurRadius="8"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Button Styles -->
    <Style x:Key="FluentPrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource FluentPrimary}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentPrimary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource FluentPrimaryHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#0E5A9A"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#F3F2F1"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#E1DFDD"/>
                            <Setter Property="Foreground" Value="#A19F9D"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentSecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FluentPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentPrimary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#F3F9FD"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#EDEBE9"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="BorderBrush" Value="#E1DFDD"/>
                            <Setter Property="Foreground" Value="#A19F9D"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern TextBox Style -->
    <Style x:Key="FluentTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource FluentCardBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FluentPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FluentPrimaryHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern GroupBox Style -->
    <Style x:Key="FluentGroupBox" TargetType="GroupBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ContentPresenter x:Name="header"
                                                  ContentSource="Header"
                                                  Margin="0,0,0,12"
                                                  Grid.Row="0"/>
                                <ContentPresenter x:Name="content"
                                                  Margin="{TemplateBinding Padding}"
                                                  Grid.Row="1"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern TabControl Style -->
    <Style x:Key="FluentTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="tabPanel"
                                Background="{StaticResource FluentSurface}"
                                BorderBrush="{StaticResource FluentBorder}"
                                BorderThickness="0,0,0,1"
                                Grid.Row="0">
                            <TabPanel x:Name="headerPanel"
                                      IsItemsHost="True"
                                      Panel.ZIndex="1"
                                      Margin="16,0"/>
                        </Border>
                        <Border x:Name="contentPanel"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Grid.Row="1">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="16"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentTabItem" TargetType="TabItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter x:Name="content"
                                          ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FluentPrimary}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#F3F9FD"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern DataGrid Style -->
    <Style x:Key="FluentDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource FluentCardBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource FluentDivider}"/>
        <Setter Property="RowBackground" Value="{StaticResource FluentCardBackground}"/>
        <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="RowHeight" Value="32"/>
        <Setter Property="CellStyle">
            <Setter.Value>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E5F3FF"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentText}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="RowStyle">
            <Setter.Value>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F3F9FD"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E5F3FF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
                    <Setter Property="Foreground" Value="{StaticResource FluentText}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="BorderBrush" Value="{StaticResource FluentBorder}"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Status Indicator -->
    <Style x:Key="FluentStatusIndicator" TargetType="Ellipse">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Fill" Value="{StaticResource FluentTextSecondary}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                <Setter Property="Fill" Value="{StaticResource FluentStatusSuccess}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsConnected}" Value="False">
                <Setter Property="Fill" Value="{StaticResource FluentStatusError}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Modern Busy Overlay -->
    <Style x:Key="FluentBusyOverlay" TargetType="Border">
        <Setter Property="Background" Value="#BFFFFFFF"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Visibility" Value="Collapsed"/>
    </Style>

    <!-- Modern Loading Text -->
    <Style x:Key="FluentLoadingText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentPrimary}"/>
        <Setter Property="Margin" Value="0,12,0,0"/>
    </Style>

</ResourceDictionary>
