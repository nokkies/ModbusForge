<ui:FluentWindow x:Class="ModbusForge.ConnectionManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Connection Manager" 
        Height="540" 
        Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/Resources/ModbusForgeLOGO.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource FluentBackground}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Background="{StaticResource FluentPrimary}" Padding="20,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔌" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Connection Manager" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Connection List -->
                <Border Style="{StaticResource FluentCard}" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Connections" Style="{StaticResource FluentSubtitle}" Margin="0,0,0,12"/>
                        
                        <Border Grid.Row="1" 
                                BorderBrush="{StaticResource FluentBorder}" 
                                BorderThickness="1" 
                                CornerRadius="4">
                            <ListBox x:Name="ConnectionsList" 
                                     ItemsSource="{Binding Profiles}"
                                     SelectedItem="{Binding SelectedProfile}"
                                     SelectionChanged="ConnectionsList_SelectionChanged"
                                     BorderThickness="0"
                                     Background="White">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Margin="0,0,10,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="Gray"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                                <Setter Property="Fill" Value="#107C10"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource FluentText}"/>
                                            <TextBlock Text=" - " Foreground="{StaticResource FluentTextSecondary}"/>
                                            <TextBlock Text="{Binding IpAddress}" Foreground="{StaticResource FluentTextSecondary}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Button Content="Add" Width="70" Margin="0,0,8,0" Click="AddButton_Click" Style="{StaticResource FluentSecondaryButton}"/>
                            <Button Content="Remove" Width="70" Margin="0,0,8,0" Click="RemoveButton_Click" Style="{StaticResource FluentSecondaryButton}"/>
                            <Button Content="Clone" Width="70" Click="CloneButton_Click" Style="{StaticResource FluentSecondaryButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Connection Details -->
                <Border Grid.Column="1" Style="{StaticResource FluentCard}">
                    <Grid x:Name="DetailsPanel" IsEnabled="{Binding HasSelection}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="Name:" Grid.Row="0" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource FluentText}"/>
                        <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Padding="8,4"
                                 Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <TextBlock Text="IP Address:" Grid.Row="1" VerticalAlignment="Center" Margin="0,8,12,0" Foreground="{StaticResource FluentText}"/>
                        <TextBox x:Name="IpTextBox" Grid.Row="1" Grid.Column="1" Padding="8,4" Margin="0,8,0,0"
                                 Text="{Binding SelectedProfile.IpAddress, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <TextBlock Text="Port:" Grid.Row="2" VerticalAlignment="Center" Margin="0,8,12,0" Foreground="{StaticResource FluentText}"/>
                        <TextBox x:Name="PortTextBox" Grid.Row="2" Grid.Column="1" Padding="8,4" Margin="0,8,0,0" Width="100" HorizontalAlignment="Left"
                                 Text="{Binding SelectedProfile.Port, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <TextBlock Text="Unit ID:" Grid.Row="3" VerticalAlignment="Center" Margin="0,8,12,0" Foreground="{StaticResource FluentText}"/>
                        <TextBox x:Name="UnitIdTextBox" Grid.Row="3" Grid.Column="1" Padding="8,4" Margin="0,8,0,0" Width="100" HorizontalAlignment="Left"
                                 Text="{Binding SelectedProfile.UnitId, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <TextBlock Text="Status:" Grid.Row="4" VerticalAlignment="Center" Margin="0,8,12,0" Foreground="{StaticResource FluentText}"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" VerticalAlignment="Center"
                                   Text="{Binding SelectedProfile.Status}" FontWeight="SemiBold" Foreground="{StaticResource FluentTextSecondary}"/>
                        
                        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,20,0,0">
                            <Button x:Name="ConnectButton" Content="Connect" Width="100" Margin="0,0,10,0" Click="ConnectButton_Click" Style="{StaticResource FluentPrimaryButton}"/>
                            <Button x:Name="DisconnectButton" Content="Disconnect" Width="100" Margin="0,0,10,0" Click="DisconnectButton_Click" Style="{StaticResource FluentSecondaryButton}"/>
                            <Button x:Name="SetActiveButton" Content="Set as Active" Width="100" Click="SetActiveButton_Click" Style="{StaticResource FluentSecondaryButton}"/>
                            <ui:ProgressRing x:Name="ConnectProgressRing" Width="24" Height="24" Margin="12,0,0,0" Visibility="Collapsed" IsIndeterminate="True"/>
                        </StackPanel>
                        
                        <Border Grid.Row="6" Grid.ColumnSpan="2" Background="{StaticResource FluentSurface}" CornerRadius="4" Padding="12" Margin="0,16,0,0" VerticalAlignment="Top">
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource FluentTextSecondary}">
                                <Run Text="Tip: " FontWeight="SemiBold"/>
                                <Run Text="You can connect to multiple Modbus servers simultaneously. The 'Active' connection is used for the main window operations. Switch between connections using 'Set as Active'."/>
                            </TextBlock>
                        </Border>
                        
                        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="Save &amp; Close" Width="110" Margin="0,0,10,0" Click="SaveCloseButton_Click" Style="{StaticResource FluentPrimaryButton}"/>
                            <Button Content="Cancel" Width="90" Click="CancelButton_Click" Style="{StaticResource FluentSecondaryButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</ui:FluentWindow>
