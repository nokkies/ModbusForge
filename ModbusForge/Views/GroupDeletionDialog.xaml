<Window x:Class="ModbusForge.Views.GroupDeletionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delete Group" Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" x:Name="HeaderText"
                   FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- Preview counts -->
        <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#DDD"
                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Direct tags:"
                           Margin="0,2,16,2" Foreground="#555"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DirectTagCountText"
                           FontWeight="SemiBold" Margin="0,2"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Total tags (recursive):"
                           Margin="0,2,16,2" Foreground="#555"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RecursiveTagCountText"
                           FontWeight="SemiBold" Margin="0,2"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Sub-groups (recursive):"
                           Margin="0,2,16,2" Foreground="#555"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RecursiveSubgroupCountText"
                           FontWeight="SemiBold" Margin="0,2"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Watch entries affected:"
                           Margin="0,2,16,2" Foreground="#555"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="WatchEntryCountText"
                           FontWeight="SemiBold" Margin="0,2"/>
            </Grid>
        </Border>

        <!-- Mode selection label -->
        <TextBlock Grid.Row="2" Text="Choose what to do with the contents:"
                   FontWeight="SemiBold" Margin="0,0,0,6"/>

        <!-- Radio buttons for mode -->
        <StackPanel Grid.Row="3" Margin="4,0,0,12">
            <RadioButton x:Name="MoveToParentRadio" GroupName="DeletionMode"
                         IsChecked="True" Margin="0,4">
                <TextBlock x:Name="MoveToParentLabel" TextWrapping="Wrap"/>
            </RadioButton>
            <RadioButton x:Name="MoveToDefaultRadio" GroupName="DeletionMode"
                         Margin="0,4">
                <TextBlock x:Name="MoveToDefaultLabel" TextWrapping="Wrap"/>
            </RadioButton>
            <RadioButton x:Name="CascadeDeleteRadio" GroupName="DeletionMode"
                         Margin="0,4" Foreground="DarkRed">
                <TextBlock Text="Delete the group and ALL contents permanently (cannot be undone)"
                           Foreground="DarkRed" TextWrapping="Wrap"/>
            </RadioButton>
        </StackPanel>

        <!-- Cascade confirmation checkbox (only shown when CascadeDelete selected) -->
        <CheckBox Grid.Row="4" x:Name="ConfirmCascadeCheck"
                  Content="I understand this is permanent and cannot be undone"
                  Visibility="Collapsed"
                  Foreground="DarkRed"
                  Margin="20,0,0,12"
                  Checked="ConfirmCascadeCheck_Changed"
                  Unchecked="ConfirmCascadeCheck_Changed"/>

        <!-- Spacer -->
        <RowDefinition Grid.Row="5"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="DeleteButton" Content="Delete" Width="90"
                    Margin="0,0,10,0" Click="Delete_Click" IsDefault="True"
                    Background="#CC3333" Foreground="White" FontWeight="SemiBold"/>
            <Button Content="Cancel" Width="90" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
