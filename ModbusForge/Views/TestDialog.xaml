<Window x:Class="ModbusForge.Views.TestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Test Dialog" Height="300" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Test Dialog - Manual Control Setting" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock x:Name="DebugText" Text="Loading..." Margin="0,0,0,10" TextWrapping="Wrap"/>
            <ComboBox x:Name="TestComboBox" Margin="0,0,0,10" Height="25"/>
            <TextBox x:Name="TestTextBox" Margin="0,0,0,10" Height="30" MinWidth="100"/>
            <Button Content="OK" Click="OK_Click" Height="30" Width="80" HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</Window>
