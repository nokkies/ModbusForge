<mah:MetroWindow x:Class="ModbusForge.Views.ConnectorConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ModbusForge.Views"
        xmlns:models="clr-namespace:ModbusForge.Models"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        Title="Connector Configuration" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Configure Connector" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
        
        <!-- Connector Info -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="10" CornerRadius="4" Margin="0,0,0,15">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="{Binding ConnectorInfo}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding NodeInfo}" FontSize="12" Foreground="Gray"/>
            </StackPanel>
        </Border>
        
        <!-- Configuration Options -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical">
                
                <!-- Link to Tag Option -->
                <GroupBox Header="Link to Modbus Tag" Margin="0,0,0,15">
                    <StackPanel Orientation="Vertical">
                        <CheckBox Content="Connect to Modbus address" IsChecked="{Binding IsLinkedToAddress}" Margin="0,0,0,10"/>
                        
                        <Grid IsEnabled="{Binding IsLinkedToAddress}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Area:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" SelectedItem="{Binding SelectedArea}" 
                                      ItemsSource="{Binding AvailableAreas}" Margin="0,0,10,5"/>
                            
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Address:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Address}" Margin="0,0,0,5"/>
                            
                            <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="NOT (invert signal)" 
                                      IsChecked="{Binding IsInverted}" Margin="0,5,0,0"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Tag Name:" VerticalAlignment="Center" Margin="0,5,10,0"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding TagName}" Margin="0,5,0,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
                
                <!-- Available Tags -->
                <GroupBox Header="Available Tags" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox Width="200" Text="{Binding TagFilter}" Margin="0,0,10,0" 
                                     mah:TextBoxHelper.Watermark="Filter tags..."/>
                            <Button Content="Refresh" Command="{Binding RefreshTagsCommand}" Padding="10,3"/>
                        </StackPanel>
                        
                        <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredTags}" 
                                  SelectedItem="{Binding SelectedTag}"
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  Height="150">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tag Name" Binding="{Binding TagName}" Width="*"/>
                                <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="80"/>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="80"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
                                <DataGridTextColumn Header="Current Value" Binding="{Binding CurrentValue}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>
                
                <!-- Quick Connect -->
                <GroupBox Header="Quick Connect" Margin="0,0,0,15">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Recently used addresses:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ItemsControl ItemsSource="{Binding RecentAddresses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="#DDD" BorderThickness="1" 
                                           Padding="8,4" Margin="0,2" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Address}" Foreground="Gray"/>
                                            <Button Content="Connect" Command="{Binding DataContext.QuickConnectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   CommandParameter="{Binding}" Margin="10,0,0,0" Padding="8,2"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="Green" Margin="0,10,0,10" 
                   Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Command="{Binding OkCommand}" IsDefault="True" Padding="20,5" Margin="0,0,10,0"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" IsCancel="True" Padding="20,5"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
