<ui:FluentWindow x:Class="ModbusForge.Views.ConnectorConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ModbusForge.Views"
        xmlns:models="clr-namespace:ModbusForge.Models"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Connector Configuration" 
        Height="420" 
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/ModbusForgeLOGO.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource FluentBackground}" Padding="0">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Configure Connector" Style="{StaticResource FluentSubtitle}" Margin="0,0,0,15"/>
            
            <!-- Connector Info -->
            <Border Grid.Row="1" Background="{StaticResource FluentSurface}" Padding="12" CornerRadius="8" Margin="0,0,0,15">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding ConnectorInfo}" FontWeight="SemiBold" Foreground="{StaticResource FluentText}"/>
                    <TextBlock Text="{Binding NodeInfo}" FontSize="12" Foreground="{StaticResource FluentTextSecondary}"/>
                </StackPanel>
            </Border>
            
            <!-- Configuration Options -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Vertical">
                    
                    <!-- Link to Tag Option -->
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Link to Modbus Tag" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch x:Name="LinkCheckBox" Content="Connect to Modbus address" IsChecked="{Binding IsLinkedToAddress}" Margin="0,0,0,12"/>
                            
                            <Grid IsEnabled="{Binding IsLinkedToAddress}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Area:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource FluentText}"/>
                                <ComboBox x:Name="AreaComboBox" Grid.Row="0" Grid.Column="1" SelectedItem="{Binding SelectedArea}" 
                                          ItemsSource="{Binding AvailableAreas}" Margin="0,0,10,8" Padding="8,4"/>
                                
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Address:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox x:Name="AddressTextBox" Grid.Row="0" Grid.Column="3" Text="{Binding Address}" Padding="8,4" Margin="0,0,0,8"/>
                                
                                <ui:ToggleSwitch x:Name="InvertCheckBox" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="NOT (invert signal)" 
                                                 IsChecked="{Binding IsInverted}"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Tag Name:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding TagName}" Padding="8,4"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Available Tags -->
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Available Tags" Style="{StaticResource FluentSubtitle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <ui:TextBox Width="200" Text="{Binding TagFilter}" Margin="0,0,10,0" PlaceholderText="Filter tags..."/>
                                <Button Content="Refresh" Command="{Binding RefreshTagsCommand}" Style="{StaticResource FluentSecondaryButton}"/>
                            </StackPanel>
                            
                            <DataGrid ItemsSource="{Binding FilteredTags}" 
                                      SelectedItem="{Binding SelectedTag}"
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="False"
                                      SelectionMode="Single"
                                      Height="150"
                                      Style="{StaticResource FluentDataGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tag Name" Binding="{Binding TagName}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="80" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="80" IsReadOnly="True"/>
                                    <DataGridComboBoxColumn Header="Type" SelectedItemBinding="{Binding Type}" Width="100">
                                        <DataGridComboBoxColumn.ElementStyle>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="ItemsSource" Value="{Binding AvailableTypes}"/>
                                            </Style>
                                        </DataGridComboBoxColumn.ElementStyle>
                                        <DataGridComboBoxColumn.EditingElementStyle>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="ItemsSource" Value="{Binding AvailableTypes}"/>
                                            </Style>
                                        </DataGridComboBoxColumn.EditingElementStyle>
                                    </DataGridComboBoxColumn>
                                    <DataGridTextColumn Header="Current Value" Binding="{Binding CurrentValue}" Width="100" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Quick Connect -->
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Quick Connect" Style="{StaticResource FluentSubtitle}"/>
                            <TextBlock Text="Recently used addresses:" Margin="0,0,0,8" Foreground="{StaticResource FluentText}"/>
                            <ItemsControl ItemsSource="{Binding RecentAddresses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource FluentCardBackground}" BorderBrush="{StaticResource FluentBorder}" BorderThickness="1" 
                                                Padding="8,4" Margin="0,2" CornerRadius="4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Margin="0,0,10,0" Foreground="{StaticResource FluentText}"/>
                                                <TextBlock Text="{Binding Address}" Foreground="{StaticResource FluentTextSecondary}"/>
                                                <Button Content="Connect" Command="{Binding DataContext.QuickConnectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" Margin="10,0,0,0" Style="{StaticResource FluentSecondaryButton}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Status -->
            <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="{StaticResource FluentStatusSuccess}" Margin="0,10,0,10" FontWeight="SemiBold"
                       Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}"/>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Command="{Binding OkCommand}" IsDefault="True" Style="{StaticResource FluentPrimaryButton}" Margin="0,0,10,0"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}" IsCancel="True" Style="{StaticResource FluentSecondaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</ui:FluentWindow>
