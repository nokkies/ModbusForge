<Window x:Class="ModbusForge.Views.WatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Watch Window - Real-time Monitoring" 
        Height="500" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="0" Background="#F0F0F0">
            <ToolBar>
                <Button Content="Add Tag" Click="AddTag_Click" Padding="8,4" Margin="2"/>
                <Button Content="Remove" Click="Remove_Click" Padding="8,4" Margin="2"/>
                <Button Content="Clear All" Click="ClearAll_Click" Padding="8,4" Margin="2"/>
                <Separator/>
                <Button Content="Start" Click="Start_Click" Padding="8,4" Margin="2"/>
                <Button Content="Stop" Click="Stop_Click" Padding="8,4" Margin="2"/>
                <Separator/>
                <TextBlock Text="Update:" VerticalAlignment="Center" Margin="5,0"/>
                <ComboBox x:Name="UpdateRateCombo" Width="80" SelectedIndex="2" SelectionChanged="UpdateRate_Changed">
                    <ComboBoxItem Content="100 ms"/>
                    <ComboBoxItem Content="500 ms"/>
                    <ComboBoxItem Content="1000 ms"/>
                    <ComboBoxItem Content="2000 ms"/>
                    <ComboBoxItem Content="5000 ms"/>
                </ComboBox>
            </ToolBar>
        </ToolBarTray>

        <!-- Watch List -->
        <DataGrid x:Name="WatchGrid" Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="All"
                  AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Group" Binding="{Binding TagGroup}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Tag Name" Binding="{Binding TagName}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Value" Binding="{Binding FormattedValue}" Width="120" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="#007ACC"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Last Updated" Binding="{Binding LastUpdated, StringFormat=HH:mm:ss.fff}" Width="100" IsReadOnly="True"/>
                <DataGridCheckBoxColumn Header="Stale" Binding="{Binding IsStale}" Width="50" IsReadOnly="True"/>
                <DataGridTextColumn Header="Alarm" Binding="{Binding AlarmMessage}" Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Red"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Height="24">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Stopped"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="WatchCountText" Text="0 entries"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
