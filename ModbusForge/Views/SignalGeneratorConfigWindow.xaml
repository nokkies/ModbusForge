<ui:FluentWindow x:Class="ModbusForge.Views.SignalGeneratorConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ModbusForge.Behaviors"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Configure Signal Generator" Height="220" Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="{StaticResource LightMetallicWhiteBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Waveform:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold" FontSize="11"/>
        <ComboBox x:Name="WaveformCombo" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <TextBlock Text="Period (ms):" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold" FontSize="11"/>
        <TextBox x:Name="PeriodText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Padding="4"
                 behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="UInteger"/>

        <TextBlock Text="Height/Amp:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold" FontSize="11"/>
        <TextBox x:Name="AmplitudeText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Padding="4"
                 behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="Decimal"/>

        <TextBlock Text="Offset:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,15" FontWeight="SemiBold" FontSize="11"/>
        <TextBox x:Name="OffsetText" Grid.Row="3" Grid.Column="1" Margin="0,0,0,15" Padding="4"
                 behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="Decimal"/>

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="80" Height="24" Margin="0,0,10,0" Click="Save_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Height="24" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
