<Window x:Class="ModbusForge.Views.TagBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tag Browser - Symbolic Addressing" 
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="0" Background="#F0F0F0">
            <ToolBar>
                <Button Content="New Group" Click="NewGroup_Click" Padding="8,4" Margin="2"/>
                <Button Content="New Tag" Click="NewTag_Click" Padding="8,4" Margin="2"/>
                <Separator/>
                <Button Content="Delete" Click="Delete_Click" Padding="8,4" Margin="2"/>
                <Separator/>
                <Button Content="Import" Click="Import_Click" Padding="8,4" Margin="2"/>
                <Button Content="Export" Click="Export_Click" Padding="8,4" Margin="2"/>
                <Separator/>
                <Button Content="Add to Watch" Click="AddToWatch_Click" Padding="8,4" Margin="2"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tree View -->
            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,1,0">
                <ScrollViewer>
                    <TreeView x:Name="TagTreeView" SelectedItemChanged="TagTreeView_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding SubGroups}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁" Margin="0,0,4,0" FontSize="14"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" (" Foreground="#666"/>
                                    <TextBlock Text="{Binding TotalTagCount}" Foreground="#666"/>
                                    <TextBlock Text=")" Foreground="#666"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>
            </Border>

            <!-- Grid Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDD"/>

            <!-- Details Panel -->
            <ScrollViewer Grid.Column="2" Margin="10">
                <StackPanel x:Name="DetailsPanel" Visibility="Collapsed">
                    <!-- Tag Details -->
                    <GroupBox Header="Tag Properties" Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Margin="0,4" VerticalAlignment="Center"/>
                            <TextBox x:Name="TagNameBox" Grid.Row="0" Grid.Column="1" Margin="5,2" TextChanged="TagProperty_Changed"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Group:" Margin="0,4" VerticalAlignment="Center"/>
                            <ComboBox x:Name="TagGroupCombo" Grid.Row="1" Grid.Column="1" Margin="5,2" SelectionChanged="TagProperty_Changed"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Description:" Margin="0,4" VerticalAlignment="Center"/>
                            <TextBox x:Name="TagDescriptionBox" Grid.Row="2" Grid.Column="1" Margin="5,2" TextWrapping="Wrap" Height="60" TextChanged="TagProperty_Changed"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Modbus Area:" Margin="0,4" VerticalAlignment="Center"/>
                            <ComboBox x:Name="TagAreaCombo" Grid.Row="3" Grid.Column="1" Margin="5,2" SelectionChanged="TagProperty_Changed">
                                <ComboBoxItem Content="Holding Register"/>
                                <ComboBoxItem Content="Coil"/>
                                <ComboBoxItem Content="Input Register"/>
                                <ComboBoxItem Content="Discrete Input"/>
                            </ComboBox>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Address:" Margin="0,4" VerticalAlignment="Center"/>
                            <TextBox x:Name="TagAddressBox" Grid.Row="4" Grid.Column="1" Margin="5,2" TextChanged="TagProperty_Changed"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Data Type:" Margin="0,4" VerticalAlignment="Center"/>
                            <ComboBox x:Name="TagDataTypeCombo" Grid.Row="5" Grid.Column="1" Margin="5,2" SelectionChanged="TagProperty_Changed">
                                <ComboBoxItem Content="Bool"/>
                                <ComboBoxItem Content="Int16"/>
                                <ComboBoxItem Content="UInt16"/>
                                <ComboBoxItem Content="Int32"/>
                                <ComboBoxItem Content="UInt32"/>
                                <ComboBoxItem Content="Float"/>
                                <ComboBoxItem Content="Double"/>
                                <ComboBoxItem Content="String"/>
                            </ComboBox>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Scale:" Margin="0,4" VerticalAlignment="Center"/>
                            <TextBox x:Name="TagScaleBox" Grid.Row="6" Grid.Column="1" Margin="5,2" TextChanged="TagProperty_Changed"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Offset:" Margin="0,4" VerticalAlignment="Center"/>
                            <TextBox x:Name="TagOffsetBox" Grid.Row="7" Grid.Column="1" Margin="5,2" TextChanged="TagProperty_Changed"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Units:" Margin="0,4" VerticalAlignment="Center"/>
                            <TextBox x:Name="TagUnitsBox" Grid.Row="8" Grid.Column="1" Margin="5,2" TextChanged="TagProperty_Changed"/>
                        </Grid>
                    </GroupBox>

                    <!-- Current Value -->
                    <GroupBox Header="Current Value" Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Raw Value:" Margin="0,4" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CurrentRawValue" Grid.Row="0" Grid.Column="1" Margin="5,2" FontWeight="Bold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Scaled Value:" Margin="0,4" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CurrentScaledValue" Grid.Row="1" Grid.Column="1" Margin="5,2" FontWeight="Bold" Foreground="#007ACC"/>
                        </Grid>
                    </GroupBox>

                    <!-- Alarms -->
                    <GroupBox Header="Alarms" Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <CheckBox x:Name="AlarmEnabledCheck" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="Enable Alarms" Margin="0,4" Checked="AlarmSetting_Changed" Unchecked="AlarmSetting_Changed"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="High Limit:" Margin="0,4" VerticalAlignment="Center"/>
                            <TextBox x:Name="AlarmHighBox" Grid.Row="1" Grid.Column="1" Margin="5,2" TextChanged="AlarmSetting_Changed"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Low Limit:" Margin="0,4" VerticalAlignment="Center"/>
                            <TextBox x:Name="AlarmLowBox" Grid.Row="2" Grid.Column="1" Margin="5,2" TextChanged="AlarmSetting_Changed"/>
                        </Grid>
                    </GroupBox>

                    <Button Content="Save Changes" Click="SaveChanges_Click" Padding="10,5" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Height="24">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TagCountText" Text="0 tags"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
