<ui:FluentWindow x:Class="ModbusForge.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:behaviors="clr-namespace:ModbusForge.Behaviors"
        Title="Preferences" 
        Height="520" 
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/ModbusForgeLOGO.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource FluentBackground}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Background="{StaticResource FluentPrimary}" Padding="20,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Preferences" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource FluentCardBackground}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,16,16,0">
                <StackPanel>
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Connection" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch x:Name="AutoReconnectCheckBox" 
                                             Content="Auto-reconnect on connection loss" 
                                             Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Reconnect interval (ms):" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox x:Name="ReconnectIntervalTextBox" Width="90" Text="5000" Padding="8,4"
                                         behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="UInteger"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Diagnostics" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch x:Name="ShowDiagnosticsOnErrorCheckBox" 
                                             Content="Show diagnostics dialog on connection error"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Console" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch x:Name="EnableConsoleLoggingCheckBox" 
                                             Content="Enable console logging" 
                                             Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Max console messages:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox x:Name="MaxConsoleMessagesTextBox" Width="90" Text="1000" Padding="8,4"
                                         behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="UInteger"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Performance" Style="{StaticResource FluentSubtitle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Max concurrent trend requests:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox x:Name="MaxConcurrentTrendRequestsTextBox" Width="90" Text="8" Padding="8,4"
                                         behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="UInteger"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Application" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch x:Name="ConfirmOnExitCheckBox" Content="Confirm before exiting application"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="API (Requires Restart)" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch x:Name="EnableApiCheckBox" 
                                             Content="Enable REST API / MCP" 
                                             Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="API Port:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox x:Name="ApiPortTextBox" Width="90" Text="5000" Padding="8,4"
                                         behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="UInteger"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer -->
            <Border Grid.Row="2" 
                    Background="{StaticResource FluentSurface}" 
                    BorderBrush="{StaticResource FluentBorder}" 
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save" Width="90" Margin="0,0,10,0" Click="SaveButton_Click" Style="{StaticResource FluentPrimaryButton}"/>
                    <Button Content="Cancel" Width="90" Click="CancelButton_Click" Style="{StaticResource FluentSecondaryButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</ui:FluentWindow>
