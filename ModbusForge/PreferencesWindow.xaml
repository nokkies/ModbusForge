<ui:FluentWindow x:Class="ModbusForge.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:behaviors="clr-namespace:ModbusForge.Behaviors"
        Title="Preferences" 
        Height="520" 
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/ModbusForgeLOGO.png"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/FluentTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource FluentBackground}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Background="{StaticResource FluentPrimary}" Padding="20,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Preferences" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource FluentCardBackground}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,16,16,0">
                <StackPanel>
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Connection" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch Content="Auto-reconnect on connection loss" 
                                             Margin="0,0,0,12"
                                             IsChecked="{Binding AutoReconnect, Mode=TwoWay}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Reconnect interval (ms):" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox Width="90" Padding="8,4"
                                         Text="{Binding AutoReconnectIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="UInteger"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Diagnostics" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch Content="Show diagnostics dialog on connection error"
                                             IsChecked="{Binding ShowConnectionDiagnosticsOnError, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Console" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch Content="Enable console logging" 
                                             Margin="0,0,0,12"
                                             IsChecked="{Binding EnableConsoleLogging, Mode=TwoWay}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Max console messages:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox Width="90" Padding="8,4"
                                         Text="{Binding MaxConsoleMessages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="UInteger"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Performance" Style="{StaticResource FluentSubtitle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Max concurrent trend requests:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox Width="90" Padding="8,4"
                                         Text="{Binding MaxConcurrentTrendRequests, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="UInteger"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="Application" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch Content="Confirm before exiting application"
                                             IsChecked="{Binding ConfirmOnExit, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource FluentCard}">
                        <StackPanel>
                            <TextBlock Text="API (Requires Restart)" Style="{StaticResource FluentSubtitle}"/>
                            <ui:ToggleSwitch x:Name="EnableApiCheckBox" 
                                             Content="Enable REST API / MCP" 
                                             Margin="0,0,0,12"
                                             IsChecked="{Binding EnableApi, Mode=TwoWay}"
                                             Checked="EnableApiCheckBox_Changed"
                                             Unchecked="EnableApiCheckBox_Changed"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="API Port:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox Width="90" Padding="8,4"
                                         Text="{Binding ApiPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         behaviors:NumericTextBoxBehavior.IsNumeric="True" behaviors:NumericTextBoxBehavior.Format="UInteger"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="EnableApiDocumentationCheckBox" 
                                             Content="Enable API documentation (Swagger)" 
                                             Margin="0,0,0,12"
                                             IsChecked="{Binding EnableApiDocumentation, Mode=TwoWay}"/>
                            <ui:ToggleSwitch x:Name="EnableApiAuthenticationCheckBox" 
                                             Content="Require API key for mutations" 
                                             Margin="0,0,0,12"
                                             IsChecked="{Binding EnableApiAuthentication, Mode=TwoWay}"
                                             Checked="EnableApiAuthenticationCheckBox_Changed"
                                             Unchecked="EnableApiAuthenticationCheckBox_Changed"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="API Key:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{StaticResource FluentText}"/>
                                <TextBox x:Name="ApiKeyTextBox" Width="280" IsReadOnly="True" Padding="8,4" FontFamily="Consolas"
                                         Text="{Binding ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button x:Name="CopyApiKeyButton" Content="Copy" Width="60" Margin="8,0,0,0" Click="CopyApiKeyButton_Click" Style="{StaticResource FluentSecondaryButton}"/>
                                <Button x:Name="RegenerateApiKeyButton" Content="New" Width="60" Margin="8,0,0,0" Click="RegenerateApiKeyButton_Click" Style="{StaticResource FluentSecondaryButton}"/>
                            </StackPanel>
                            <TextBlock x:Name="ApiKeyWarningTextBlock" 
                                       Text="Warning: API is enabled without authentication. Any local process can call state-changing endpoints." 
                                       Foreground="Red" 
                                       TextWrapping="Wrap" 
                                       FontSize="12"
                                       Visibility="Collapsed"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer -->
            <Border Grid.Row="2" 
                    Background="{StaticResource FluentSurface}" 
                    BorderBrush="{StaticResource FluentBorder}" 
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save" Width="90" Margin="0,0,10,0" Command="{Binding SaveCommand}" Style="{StaticResource FluentPrimaryButton}"/>
                    <Button Content="Cancel" Width="90" Command="{Binding CancelCommand}" Style="{StaticResource FluentSecondaryButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</ui:FluentWindow>
